# ==================================
# Money in Motion — Configuration
# ==================================

# --- REQUIRED ---

# SEC EDGAR (free, but requires email for User-Agent header)
CONTACT_EMAIL=your-email@example.com

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
SCORING_MODEL=claude-sonnet-4-6

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
# SUPABASE_SERVICE_KEY=your-service-role-key  # Only for admin operations

# Webhook Server Auth (REQUIRED if exposing /run endpoint)
API_AUTH_TOKEN=generate-a-secure-random-token-here

# --- ENRICHMENT (optional) ---

# Apollo.io (free: 10k credits/month)
APOLLO_API_KEY=

# Prospeo.io (fallback, $39/mo for 1k credits)
PROSPEO_API_KEY=

# --- EMAIL ALERTS (optional) ---

ALERT_EMAIL=advisor@coregrowth.ai
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# --- LINKEDIN DETECTION (optional) ---

APIFY_TOKEN=
TARGET_COMPANY_URLS=https://linkedin.com/company/datadog,https://linkedin.com/company/snowflake
APIFY_TIMEOUT_SECONDS=300

# --- WARN ACT ---

TARGET_STATES=CO,CA,NY,TX,FL

# --- COST CIRCUIT BREAKERS ---
# Prevents runaway API spend during filing bursts (earnings season, M&A waves)

MAX_CLAUDE_CALLS_PER_RUN=200
MAX_ENRICHMENT_CALLS_PER_RUN=500
MAX_EVENTS_PER_RUN=300
MAX_T1_ALERTS_PER_RUN=20

# --- PIPELINE ---

DEFAULT_LOOKBACK_HOURS=24
SEC_RATE_LIMIT=8
SEC_RETRY_ATTEMPTS=3
LOCAL_CACHE_DIR=.cache
